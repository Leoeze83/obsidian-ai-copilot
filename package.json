{
  "name": "obsidian-ai-copilot",
  "version": "1.0.0",
  "description": "AI Copilot plugin for Obsidian powered by Google Gemini",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "ai",
    "gemini",
    "copilot"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "builtin-modules": "3.3.0",
    "esbuild": "0.21.5",
    "obsidian": "latest",
    "tslib": "2.6.2",
    "typescript": "5.3.3"
  },
  "allowScripts": {
    "esbuild@0.21.5": true
  }
}
